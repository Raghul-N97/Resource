<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WhatsApp Lead Qualification AI — SOP</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #25D366;
    --green-dark: #128C7E;
    --green-light: #DCF8C6;
    --green-mid: #075E54;
    --ink: #111827;
    --ink-mid: #374151;
    --ink-soft: #6B7280;
    --surface: #F9FAFB;
    --surface-2: #F3F4F6;
    --border: #E5E7EB;
    --white: #FFFFFF;
    --amber: #F59E0B;
    --amber-light: #FEF3C7;
    --coral: #EF4444;
    --coral-light: #FEE2E2;
    --blue: #3B82F6;
    --blue-light: #EFF6FF;
    --purple: #8B5CF6;
    --purple-light: #EDE9FE;
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    color: var(--ink);
    background: var(--surface);
    line-height: 1.7;
    font-size: 15px;
  }

  /* HEADER */
  .header {
    background: var(--green-mid);
    color: white;
    padding: 56px 48px 48px;
    position: relative;
    overflow: hidden;
  }
  .header::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 360px; height: 360px;
    border-radius: 50%;
    background: rgba(37,211,102,0.12);
  }
  .header::after {
    content: '';
    position: absolute;
    bottom: -40px; left: 40%;
    width: 220px; height: 220px;
    border-radius: 50%;
    background: rgba(37,211,102,0.07);
  }
  .header-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(37,211,102,0.2);
    border: 1px solid rgba(37,211,102,0.3);
    color: #86efac;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 20px;
    margin-bottom: 20px;
  }
  .header h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 38px;
    font-weight: 400;
    line-height: 1.2;
    color: white;
    max-width: 660px;
    margin-bottom: 14px;
    position: relative;
  }
  .header h1 em {
    font-style: italic;
    color: var(--green);
  }
  .header-sub {
    color: rgba(255,255,255,0.65);
    font-size: 15px;
    max-width: 560px;
    margin-bottom: 32px;
    position: relative;
  }
  .header-meta {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    position: relative;
  }
  .meta-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 7px 14px;
    border-radius: 20px;
    font-size: 13px;
    color: rgba(255,255,255,0.85);
  }
  .meta-pill .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--green);
  }

  /* AFFILIATE DISCLOSURE */
  .affiliate-disclosure {
    background: #FFFBEB;
    border-left: 4px solid #D97706;
    border-bottom: 1px solid #FDE68A;
    padding: 14px 32px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 13px;
    color: #78350F;
  }
  .affiliate-disclosure .disc-icon {
    font-size: 16px;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .affiliate-disclosure strong { color: #92400E; font-weight: 600; }
  .affiliate-disclosure a { color: #92400E; text-decoration: underline; }

  /* PROBLEM BANNER */
  .problem-banner {
    background: #FFF7ED;
    border-left: 4px solid var(--amber);
    padding: 20px 32px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .problem-icon {
    font-size: 28px;
    flex-shrink: 0;
  }
  .problem-banner strong { color: #92400E; font-weight: 600; }
  .problem-banner p { color: #78350F; font-size: 14px; }

  /* MAIN */
  .main { max-width: 880px; margin: 0 auto; padding: 0 32px 64px; }

  /* SECTION HEADERS */
  .section-label {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 48px 0 20px;
  }
  .section-num {
    width: 32px; height: 32px;
    background: var(--green);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    flex-shrink: 0;
  }
  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    font-weight: 400;
  }

  /* FLOW DIAGRAM */
  .flow-diagram {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin: 24px 0;
    overflow-x: auto;
  }
  .flow-step {
    flex: 1;
    min-width: 120px;
    padding: 18px 16px;
    background: white;
    border: 1px solid var(--border);
    position: relative;
    text-align: center;
  }
  .flow-step:first-child { border-radius: var(--radius-md) 0 0 var(--radius-md); }
  .flow-step:last-child  { border-radius: 0 var(--radius-md) var(--radius-md) 0; }
  .flow-step:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--green);
    font-size: 18px;
    font-weight: 700;
    z-index: 1;
    background: white;
    padding: 0 2px;
  }
  .flow-step .step-icon { font-size: 24px; margin-bottom: 8px; }
  .flow-step .step-label {
    font-size: 12px; font-weight: 600;
    color: var(--ink-mid); line-height: 1.3;
  }
  .flow-step .step-sub {
    font-size: 10px; color: var(--ink-soft);
    margin-top: 4px; line-height: 1.3;
  }
  .flow-step.active-step { background: var(--green-light); border-color: var(--green); }
  .flow-step.active-step .step-label { color: var(--green-dark); }

  /* INTENT CARDS */
  .intent-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin: 20px 0;
  }
  .intent-card {
    padding: 18px 20px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: white;
  }
  .intent-card .intent-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 10px;
  }
  .intent-card.buy .intent-tag   { background: #DCFCE7; color: #166534; }
  .intent-card.price .intent-tag { background: var(--blue-light); color: #1E40AF; }
  .intent-card.support .intent-tag { background: var(--amber-light); color: #92400E; }
  .intent-card.spam .intent-tag  { background: var(--coral-light); color: #991B1B; }
  .intent-card .intent-title { font-weight: 600; font-size: 14px; margin-bottom: 6px; color: var(--ink); }
  .intent-card .intent-desc  { font-size: 13px; color: var(--ink-soft); line-height: 1.5; }
  .intent-card .intent-action {
    margin-top: 10px; font-size: 12px; font-weight: 600;
    padding: 5px 10px; border-radius: var(--radius-sm); display: inline-block;
  }
  .intent-card.buy .intent-action   { background: #DCFCE7; color: #166534; }
  .intent-card.price .intent-action { background: var(--blue-light); color: #1E40AF; }
  .intent-card.support .intent-action { background: var(--amber-light); color: #92400E; }
  .intent-card.spam .intent-action  { background: var(--coral-light); color: #991B1B; }

  /* STEP CARDS */
  .step-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 24px 28px;
    margin-bottom: 16px;
    position: relative;
  }
  .step-card.featured {
    border-color: var(--green);
    border-width: 2px;
  }
  .step-card-header {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
  }
  .step-num-big {
    width: 42px; height: 42px;
    border-radius: 50%;
    background: var(--ink);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Serif Display', serif;
    font-size: 18px;
    flex-shrink: 0;
  }
  .step-num-big.green-num { background: var(--green-dark); }
  .step-card-title { font-weight: 600; font-size: 16px; color: var(--ink); margin-bottom: 3px; }
  .step-card-sub { font-size: 13px; color: var(--ink-soft); }
  .step-card .time-badge {
    position: absolute;
    top: 20px; right: 20px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 11px;
    color: var(--ink-soft);
    font-weight: 500;
  }
  .step-body { font-size: 14px; color: var(--ink-mid); line-height: 1.7; }
  .step-body ul { padding-left: 20px; margin: 10px 0; }
  .step-body li { margin-bottom: 6px; }
  .step-body strong { color: var(--ink); font-weight: 600; }
  .step-body p + p { margin-top: 10px; }

  /* AFFILIATE LINK BUTTON */
  .aff-link-box {
    background: var(--green-light);
    border: 2px solid var(--green);
    border-radius: var(--radius-md);
    padding: 18px 22px;
    margin: 16px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .aff-link-box .aff-text { font-size: 14px; color: var(--green-mid); }
  .aff-link-box .aff-text strong { color: var(--green-dark); font-weight: 700; font-size: 15px; display: block; margin-bottom: 3px; }
  .aff-link-box a.aff-btn {
    background: var(--green-dark);
    color: white;
    padding: 10px 22px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    white-space: nowrap;
    display: inline-block;
  }
  .aff-link-box a.aff-btn:hover { background: var(--green-mid); }

  /* PLAN COMPARISON */
  .plan-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin: 14px 0;
  }
  .plan-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px;
    text-align: center;
  }
  .plan-card.recommended {
    background: white;
    border-color: var(--green);
    border-width: 2px;
  }
  .plan-card .plan-tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-dark);
    background: var(--green-light);
    padding: 2px 8px;
    border-radius: 10px;
    display: inline-block;
    margin-bottom: 8px;
  }
  .plan-card .plan-name { font-weight: 600; font-size: 15px; margin-bottom: 4px; }
  .plan-card .plan-price { font-size: 22px; font-weight: 700; color: var(--green-dark); margin-bottom: 4px; }
  .plan-card .plan-ops { font-size: 11px; color: var(--ink-soft); }

  /* HELP CHANNELS */
  .help-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin: 20px 0;
  }
  .help-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 18px 20px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }
  .help-card:hover { border-color: var(--green); }
  .help-card .help-icon {
    font-size: 26px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .help-card .help-title { font-weight: 600; font-size: 14px; color: var(--ink); margin-bottom: 3px; }
  .help-card .help-desc  { font-size: 12px; color: var(--ink-soft); line-height: 1.5; }
  .help-card .help-link  { font-size: 12px; color: var(--green-dark); font-weight: 500; margin-top: 5px; display: block; }

  /* HELP NOTICE */
  .help-notice {
    background: var(--blue-light);
    border: 1px solid #BFDBFE;
    border-radius: var(--radius-md);
    padding: 16px 20px;
    font-size: 13px;
    color: #1E40AF;
    margin: 14px 0;
  }
  .help-notice strong { font-weight: 600; }

  /* CODE BLOCK */
  .code-block {
    background: #0F172A;
    border-radius: var(--radius-md);
    padding: 20px 24px;
    margin: 14px 0;
    font-family: 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.6;
    overflow-x: auto;
  }

  /* TOOLS ROW */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin: 20px 0;
  }
  .tool-chip {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px 14px;
    text-align: center;
  }
  .tool-chip .tool-icon { font-size: 26px; margin-bottom: 8px; }
  .tool-chip .tool-name { font-size: 13px; font-weight: 600; color: var(--ink); margin-bottom: 3px; }
  .tool-chip .tool-role { font-size: 11px; color: var(--ink-soft); line-height: 1.3; }

  /* ALERT RULES */
  .alert-rule {
    display: flex;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }
  .alert-rule:last-child { border-bottom: none; }
  .alert-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--green); margin-top: 6px; flex-shrink: 0; }
  .alert-dot.hot  { background: var(--coral); }
  .alert-dot.warm { background: var(--amber); }
  .alert-rule .rule-title { font-weight: 600; font-size: 14px; margin-bottom: 3px; }
  .alert-rule .rule-desc  { font-size: 13px; color: var(--ink-soft); }

  /* KPI GRID */
  .kpi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin: 20px 0; }
  .kpi-card { background: white; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 20px; text-align: center; }
  .kpi-num  { font-family: 'DM Serif Display', serif; font-size: 32px; color: var(--green-dark); line-height: 1; margin-bottom: 6px; }
  .kpi-label { font-size: 12px; color: var(--ink-soft); font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }

  /* PROMPT BOX */
  .prompt-box {
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-left: 3px solid var(--purple);
    border-radius: var(--radius-md);
    padding: 20px 22px;
    margin: 14px 0;
    font-family: 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.7;
    color: #334155;
    white-space: pre-wrap;
  }
  .prompt-box .label {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--purple);
    margin-bottom: 10px;
    display: block;
  }

  /* WHATSAPP BUBBLE */
  .wa-conversation {
    background: #E5DDD5;
    border-radius: var(--radius-lg);
    padding: 20px;
    margin: 16px 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c8b8a2' fill-opacity='0.3'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .bubble-row { display: flex; margin-bottom: 10px; }
  .bubble-row.right { justify-content: flex-end; }
  .bubble { max-width: 70%; padding: 10px 14px; border-radius: 12px; font-size: 13px; line-height: 1.5; }
  .bubble.incoming { background: white; border-radius: 0 12px 12px 12px; color: var(--ink); }
  .bubble.outgoing { background: #DCF8C6; border-radius: 12px 0 12px 12px; color: var(--ink); }
  .bubble-label { font-size: 10px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 4px; }
  .bubble-time  { font-size: 10px; color: var(--ink-soft); text-align: right; margin-top: 4px; }

  /* DIVIDER */
  .divider { border: none; border-top: 1px solid var(--border); margin: 32px 0; }

  /* TROUBLESHOOT */
  .faq-item { border-bottom: 1px solid var(--border); padding: 18px 0; }
  .faq-item:last-child { border-bottom: none; }
  .faq-q {
    font-weight: 600; font-size: 14px; color: var(--ink); margin-bottom: 8px;
    display: flex; gap: 10px; align-items: flex-start;
  }
  .faq-q::before {
    content: 'Q';
    background: var(--green-mid); color: white;
    width: 20px; height: 20px; border-radius: 50%;
    font-size: 10px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 1px;
  }
  .faq-a { font-size: 13px; color: var(--ink-soft); padding-left: 30px; line-height: 1.6; }

  /* CHECKLIST */
  .checklist { list-style: none; padding: 0; margin: 10px 0; }
  .checklist li {
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
    color: var(--ink-mid);
    border-bottom: 1px solid var(--surface-2);
  }
  .checklist li:last-child { border-bottom: none; }
  .checklist li::before {
    content: '○';
    color: var(--green-dark);
    font-weight: 700;
    flex-shrink: 0;
  }

  /* SCENARIO MAP */
  .scenario-map {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin: 14px 0;
  }
  .scenario-map .sm-row {
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid var(--border);
  }
  .scenario-map .sm-row:last-child { border-bottom: none; }
  .scenario-map .sm-num {
    width: 44px;
    background: var(--surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 13px;
    color: var(--ink-soft);
    flex-shrink: 0;
    border-right: 1px solid var(--border);
  }
  .scenario-map .sm-content { padding: 12px 16px; flex: 1; }
  .scenario-map .sm-title { font-weight: 600; font-size: 13px; color: var(--ink); margin-bottom: 2px; }
  .scenario-map .sm-desc  { font-size: 12px; color: var(--ink-soft); }
  .scenario-map .sm-tag {
    float: right;
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 10px;
    background: var(--blue-light);
    color: #1E40AF;
    margin-left: 8px;
  }

  /* TABLE */
  .data-table { width: 100%; border-collapse: collapse; font-size: 13px; margin: 14px 0; }
  .data-table th {
    background: var(--surface-2);
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-soft);
    border-bottom: 2px solid var(--border);
  }
  .data-table td { padding: 10px 14px; border-bottom: 1px solid var(--border); color: var(--ink-mid); vertical-align: top; }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:hover td { background: var(--surface); }

  /* CALLOUT */
  .callout {
    background: var(--green-light);
    border: 1px solid #A7F3D0;
    border-radius: var(--radius-md);
    padding: 16px 20px;
    font-size: 13px;
    color: #065F46;
    margin: 14px 0;
  }
  .callout strong { font-weight: 600; }

  /* FOOTER */
  .footer {
    background: var(--ink);
    color: rgba(255,255,255,0.5);
    text-align: center;
    padding: 24px;
    font-size: 12px;
  }
  .footer strong { color: var(--green); }
  .footer .disc-footer {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
    margin-top: 8px;
  }

  @media print {
    .header { background: #075E54 !important; -webkit-print-color-adjust: exact; }
  }
</style>
</head>
<body>

<!-- HEADER (no score badge) -->
<div class="header">
  <div class="header-tag">
    <span>●</span> Save Time Systems · Sales + CRM
  </div>
  <h1>WhatsApp Lead Qualification <em>AI</em> for Small Businesses</h1>
